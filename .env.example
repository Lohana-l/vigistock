# ----------------------------------------------------------------------------
# Vigistock: environment template.
# Copy to `.env` and fill in. No credentials are required for the demo:
# the project will run end-to-end on synthetic data + public FDA endpoints
# (which are unauthenticated).
# ----------------------------------------------------------------------------

# --- TimescaleDB ---
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_DB=vigistock
TIMESCALE_USER=vigistock
TIMESCALE_PASSWORD=change-me

# --- Redpanda (Kafka-compatible) ---
REDPANDA_BROKERS=redpanda:9092
REDPANDA_TOPIC_TELEMETRY=coldchain.telemetry
REDPANDA_TOPIC_ALERTS=coldchain.alerts

# --- MinIO (protocol PDF storage) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PROTOCOLS=protocols

# --- Ollama (local LLM) ---
# Default tuned for MacBook Air M1 8 Go: phi3:mini (~2.4 GB Q4) + bge-small-en (~130 MB).
# Switch to llama3.1:8b on a 16 GB+ host if you want richer briefs.
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=bge-small-en
OLLAMA_TEMPERATURE=0.2

# --- Streamlit demo flags ---
USE_MOCK_DATA=false  # live par defaut : sert flotte et previsions depuis TimescaleDB (repli mock automatique)
USE_LLM_MOCK=false   # real RAG path (ChromaDB + Ollama); auto-fallback to mock if Ollama is down

# --- ChromaDB (vector store for RAG) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=clinical_protocols

# --- Public data sources (no key required for the demo) ---
FDA_SHORTAGES_URL=https://api.fda.gov/drug/shortages.json
OPENFDA_URL=https://api.fda.gov/drug/label.json
ANSM_RSS_URL=https://ansm.sante.fr/actualites.rss
OPENPRESCRIBING_URL=https://openprescribing.net/api/1.0

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Dagster ---
DAGSTER_HOME=/opt/dagster/dagster_home

# --- Feature flags ---
USE_SYNTHETIC_FALLBACK=true
SIMULATOR_SITES=8
SIMULATOR_FRIDGES_PER_SITE=6
SIMULATOR_TICK_SECONDS=30
