        {
          "datasource": { "type": "postgres", "uid": "ds-timescale" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT opened_at, severity, fridge_id, site_name, duration_sec/60 AS duration_minutes, peak_temp_c FROM gold.v_alerts_active ORDER BY opened_at DESC LIMIT 50"
        }
      ],
      "title": "Active alerts",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "ds-timescale" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 50, "lineWidth": 0 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
